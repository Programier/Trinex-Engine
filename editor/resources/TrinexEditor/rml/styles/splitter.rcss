.trx-splitter {
    flex: 0 0 auto;
    border-radius: 999px;
    background-color: #202536;
}

.trx-splitter:hover {
    background-color: #31405f;
}

.trx-splitter--vertical {
    width: 6px;
    margin: 0 10px;
    cursor: col-resize;
}

.trx-splitter--horizontal {
    height: 6px;
    margin: 10px 0;
    cursor: row-resize;
}
